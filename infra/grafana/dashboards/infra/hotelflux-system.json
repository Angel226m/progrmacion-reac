{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "asDropdown": true, "icon": "external link", "includeVars": true, "keepTime": true, "tags": ["hotelflux"], "title": "HotelFlux Dashboards", "type": "dashboards" }
  ],
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "🟢 Estado de Servicios", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "mappings": [{ "options": { "0": { "color": "red", "text": "CAÍDO" }, "1": { "color": "green", "text": "ACTIVO" } }, "type": "value" }], "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } },
      "gridPos": { "h": 4, "w": 2, "x": 0, "y": 1 }, "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Backend", "type": "stat",
      "targets": [{ "expr": "hotelflux_up", "legendFormat": "Backend" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "mappings": [{ "options": { "0": { "color": "red", "text": "CAÍDO" }, "1": { "color": "green", "text": "ACTIVO" } }, "type": "value" }], "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } },
      "gridPos": { "h": 4, "w": 2, "x": 2, "y": 1 }, "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "PostgreSQL", "type": "stat",
      "targets": [{ "expr": "up{job=\"postgres\"}", "legendFormat": "Postgres" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "mappings": [{ "options": { "0": { "color": "red", "text": "CAÍDO" }, "1": { "color": "green", "text": "ACTIVO" } }, "type": "value" }], "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } },
      "gridPos": { "h": 4, "w": 2, "x": 4, "y": 1 }, "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Redis", "type": "stat",
      "targets": [{ "expr": "up{job=\"redis\"}", "legendFormat": "Redis" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "mappings": [{ "options": { "0": { "color": "red", "text": "CAÍDO" }, "1": { "color": "green", "text": "ACTIVO" } }, "type": "value" }], "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } },
      "gridPos": { "h": 4, "w": 2, "x": 6, "y": 1 }, "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Nginx", "type": "stat",
      "targets": [{ "expr": "up{job=\"nginx\"}", "legendFormat": "Nginx" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 30000 }, { "color": "red", "value": 50000 }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 2, "x": 8, "y": 1 }, "id": 5,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Procesos Erlang", "type": "stat",
      "targets": [{ "expr": "hotelflux_erlang_process_count", "legendFormat": "Procesos" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 512000000 }, { "color": "red", "value": 805306368 }] }, "unit": "bytes" } },
      "gridPos": { "h": 4, "w": 2, "x": 10, "y": 1 }, "id": 6,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Memoria VM Total", "type": "stat",
      "targets": [{ "expr": "hotelflux_erlang_memory_bytes{type=\"total\"}", "legendFormat": "Memoria" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }, "unit": "percent" } },
      "gridPos": { "h": 4, "w": 2, "x": 12, "y": 1 }, "id": 7,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "% Mem. Erlang", "type": "stat",
      "targets": [{ "expr": "job:hotelflux:erlang_memory_usage_pct", "legendFormat": "%" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] }, "unit": "percent" } },
      "gridPos": { "h": 4, "w": 2, "x": 14, "y": 1 }, "id": 8,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "% Mem. Redis", "type": "stat",
      "targets": [{ "expr": "job:hotelflux:redis_memory_usage_pct", "legendFormat": "%" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": 80 }, { "color": "yellow", "value": 50 }, { "color": "red", "value": null }] }, "unit": "percent" } },
      "gridPos": { "h": 4, "w": 2, "x": 16, "y": 1 }, "id": 9,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Redis Hit Ratio", "type": "stat",
      "targets": [{ "expr": "job:hotelflux:redis_hit_ratio_pct", "legendFormat": "Hit %" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 90 }] }, "unit": "percent" } },
      "gridPos": { "h": 4, "w": 2, "x": 18, "y": 1 }, "id": 10,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "% Mem. Host", "type": "stat",
      "targets": [{ "expr": "job:hotelflux:memory_host_available_pct", "legendFormat": "%" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 20 }, { "color": "red", "value": 10 }] }, "unit": "percent" } },
      "gridPos": { "h": 4, "w": 2, "x": 20, "y": 1 }, "id": 11,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Disco Libre %", "type": "stat",
      "targets": [{ "expr": "job:hotelflux:disk_available_pct", "legendFormat": "%" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] }, "unit": "percent" } },
      "gridPos": { "h": 4, "w": 2, "x": 22, "y": 1 }, "id": 12,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "CPU Host", "type": "stat",
      "targets": [{ "expr": "job:hotelflux:cpu_host_usage_pct", "legendFormat": "%" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "id": 101, "title": "📦 Contenedores — CPU / RAM / Red", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "percent", "min": 0, "max": 100 } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }, "id": 20,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "CPU por Contenedor (%)",
      "type": "timeseries",
      "targets": [{ "expr": "rate(container_cpu_usage_seconds_total[5m]) * 100", "legendFormat": "{{service_name}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }, "id": 21,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Memoria por Contenedor",
      "type": "timeseries",
      "targets": [{ "expr": "container_memory_usage_bytes", "legendFormat": "{{service_name}}" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "id": 102, "title": "🐘 PostgreSQL — Conexiones y Rendimiento", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 80 }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 15 }, "id": 30,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Conexiones Activas", "type": "stat",
      "targets": [{ "expr": "pg_stat_activity_count", "legendFormat": "Conexiones" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] }, "unit": "percent" } },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 15 }, "id": 31,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "% Conexiones", "type": "stat",
      "targets": [{ "expr": "job:hotelflux:pg_connection_ratio_pct", "legendFormat": "%" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 120 }] }, "unit": "s" } },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 15 }, "id": 32,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Query más larga (s)", "type": "stat",
      "targets": [{ "expr": "pg_stat_activity_max_tx_duration", "legendFormat": "Max TX duration" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] }, "unit": "bytes" } },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 15 }, "id": 33,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Tamaño BD", "type": "stat",
      "targets": [{ "expr": "pg_database_size_bytes{datname=~\".*hotelflux.*\"}", "legendFormat": "Size" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 }, "id": 34,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Conexiones PostgreSQL por Estado",
      "type": "timeseries",
      "targets": [
        { "expr": "pg_stat_activity_count{state=\"active\"}", "legendFormat": "Activas" },
        { "expr": "pg_stat_activity_count{state=\"idle\"}", "legendFormat": "Idle" },
        { "expr": "pg_stat_activity_count{state=\"idle in transaction\"}", "legendFormat": "Idle in TX" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 8 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 }, "id": 35,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Transacciones / Deadlocks",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(pg_stat_database_xact_commit{datname=~\".*hotelflux.*\"}[5m])", "legendFormat": "Commits/s" },
        { "expr": "rate(pg_stat_database_xact_rollback{datname=~\".*hotelflux.*\"}[5m])", "legendFormat": "Rollbacks/s" },
        { "expr": "rate(pg_stat_database_deadlocks{datname=~\".*hotelflux.*\"}[5m])", "legendFormat": "Deadlocks/s" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }, "id": 103, "title": "🚀 Redis — Caché y Memoria", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 }, "id": 40,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Memoria Redis",
      "type": "timeseries",
      "targets": [
        { "expr": "redis_memory_used_bytes", "legendFormat": "Usada" },
        { "expr": "redis_memory_used_rss_bytes", "legendFormat": "RSS" },
        { "expr": "redis_memory_max_bytes", "legendFormat": "Máx (128MB)" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 }, "id": 41,
      "options": { "legend": { "calcs": ["lastNotNull", "mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Redis — Hit Ratio & Ops/s",
      "type": "timeseries",
      "targets": [
        { "expr": "job:hotelflux:redis_hit_ratio_pct", "legendFormat": "Hit ratio %" },
        { "expr": "job:hotelflux:redis_ops_per_second", "legendFormat": "Cmds/s" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 8 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 }, "id": 42,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Redis — Conexiones y Keys",
      "type": "timeseries",
      "targets": [
        { "expr": "redis_connected_clients", "legendFormat": "Clientes" },
        { "expr": "rate(redis_expired_keys_total[5m])", "legendFormat": "Keys exp/s" },
        { "expr": "rate(redis_evicted_keys_total[5m])", "legendFormat": "Keys evict/s" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }, "id": 104, "title": "🌐 Nginx — Conexiones, Requests, Latencia", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 }, "id": 50,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Nginx — Request Rate",
      "type": "timeseries",
      "targets": [{ "expr": "rate(nginx_http_requests_total[5m])", "legendFormat": "req/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 }, "id": 51,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Nginx — Conexiones",
      "type": "timeseries",
      "targets": [
        { "expr": "nginx_connections_active", "legendFormat": "Activas" },
        { "expr": "nginx_connections_waiting", "legendFormat": "Waiting" },
        { "expr": "nginx_connections_idle", "legendFormat": "Idle" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 8 }, "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 }, "id": 52,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Nginx — Status por Código",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(nginx_http_requests_total{status=~\"2..\"}[5m])", "legendFormat": "2xx" },
        { "expr": "rate(nginx_http_requests_total{status=~\"4..\"}[5m])", "legendFormat": "4xx" },
        { "expr": "rate(nginx_http_requests_total{status=~\"5..\"}[5m])", "legendFormat": "5xx" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 }, "id": 105, "title": "💾 Host — Disco, CPU, Memoria", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "percent" } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 46 }, "id": 60,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Disco — Uso y Predicción",
      "type": "timeseries",
      "targets": [
        { "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/data\"} / node_filesystem_size_bytes{mountpoint=\"/data\"} * 100)", "legendFormat": "Usado %" },
        { "expr": "predict_linear(node_filesystem_avail_bytes{mountpoint=\"/data\"}[7d], 86400*30) < 0", "legendFormat": "Predicción lleno" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "percent" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 46 }, "id": 61,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "CPU Host por Modo",
      "type": "timeseries",
      "targets": [
        { "expr": "avg by (mode) (rate(node_cpu_seconds_total[5m])) * 100", "legendFormat": "{{mode}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 46 }, "id": 62,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Memoria Host",
      "type": "timeseries",
      "targets": [
        { "expr": "node_memory_Active_bytes", "legendFormat": "Activa" },
        { "expr": "node_memory_MemAvailable_bytes", "legendFormat": "Disponible" },
        { "expr": "node_memory_SwapTotal_bytes - node_memory_SwapFree_bytes", "legendFormat": "Swap usado" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 }, "id": 106, "title": "📡 Prometheus — Scraping Health", "type": "row" },
    {
