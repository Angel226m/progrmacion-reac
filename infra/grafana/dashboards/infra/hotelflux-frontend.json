{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "asDropdown": true, "icon": "external link", "includeVars": true, "keepTime": true, "tags": ["hotelflux"], "title": "HotelFlux Dashboards", "type": "dashboards" }
  ],
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "🟢 Estado de Frontends", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "CAÍDO" }, "1": { "color": "green", "text": "ACTIVO" } }, "type": "value" }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 }, "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Frontend Personal", "type": "stat",
      "targets": [{ "expr": "hotelflux:frontend_personal_up", "legendFormat": "Personal" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "CAÍDO" }, "1": { "color": "green", "text": "ACTIVO" } }, "type": "value" }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 }, "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Frontend Cliente", "type": "stat",
      "targets": [{ "expr": "hotelflux:frontend_cliente_up", "legendFormat": "Cliente" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 500 }] }, "unit": "ms" } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 }, "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Latencia Personal", "type": "stat",
      "targets": [{ "expr": "hotelflux:frontend_personal_duration_ms", "legendFormat": "ms" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 500 }] }, "unit": "ms" } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 }, "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Latencia Cliente", "type": "stat",
      "targets": [{ "expr": "hotelflux:frontend_cliente_duration_ms", "legendFormat": "ms" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0 }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 }, "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Contenedores Activos", "type": "stat",
      "targets": [{ "expr": "count(container_last_seen{service_name=~\"frontend-.*\"})", "legendFormat": "Contenedores" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0 }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 }, "id": 6,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Targets Monitoreados", "type": "stat",
      "targets": [{ "expr": "count(up{job=~\"frontend_.*\"} == 1)", "legendFormat": "Targets OK" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "id": 101, "title": "📈 Latencia Histórica", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "ms" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }, "id": 10,
      "options": { "legend": { "calcs": ["lastNotNull", "max", "mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Latencia de Health Check por Frontend",
      "type": "timeseries",
      "targets": [
        { "expr": "hotelflux:frontend_personal_duration_ms", "legendFormat": "Personal" },
        { "expr": "hotelflux:frontend_cliente_duration_ms", "legendFormat": "Cliente" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }, "id": 11,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Disponibilidad (probe_success)",
      "type": "timeseries",
      "targets": [
        { "expr": "hotelflux:frontend_personal_up", "legendFormat": "Personal (1=activo)" },
        { "expr": "hotelflux:frontend_cliente_up", "legendFormat": "Cliente (1=activo)" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "id": 102, "title": "📦 Contenedores Frontend — CPU / RAM / Red", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "percent", "min": 0, "max": 100 } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 }, "id": 20,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "CPU por Frontend",
      "type": "timeseries",
      "targets": [{ "expr": "rate(container_cpu_usage_seconds_total{name=~\"hotelflux_core_frontend-.*\"}[5m]) * 100", "legendFormat": "{{name}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 }, "id": 21,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Memoria por Frontend",
      "type": "timeseries",
      "targets": [{ "expr": "container_memory_usage_bytes{name=~\"hotelflux_core_frontend-.*\"}", "legendFormat": "{{name}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "Bps" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 }, "id": 22,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Red por Frontend",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(container_network_receive_bytes_total{name=~\"hotelflux_core_frontend-.*\"}[5m])", "legendFormat": "{{name}} RX" },
        { "expr": "rate(container_network_transmit_bytes_total{name=~\"hotelflux_core_frontend-.*\"}[5m])", "legendFormat": "{{name}} TX" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }, "id": 103, "title": "📋 Logs Recientes (Loki)", "type": "row" },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 }, "id": 30,
      "options": { "dedupStrategy": "exact", "enableLogDetails": true, "prettifyLogJson": true, "showCommonLabels": false, "showLabels": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "editorMode": "code",
        "expr": "{container_name=~\"hotelflux_core_frontend-.*\"} |= ``",
        "queryType": "range",
        "refId": "A"
      }],
      "title": "Logs — Frontends",
      "type": "logs"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["hotelflux", "frontend", "monitoring", "health"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "HotelFlux — Frontends",
  "uid": "hotelflux-frontend-v1",
  "version": 1
}
