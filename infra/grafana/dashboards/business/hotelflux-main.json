      "type": "timeseries",
      "targets": [
        { "expr": "up{job=\"hotelflux_backend\"}", "legendFormat": "Backend UP" },
        { "expr": "predict_linear(up{job=\"hotelflux_backend\"}[1h], 86400)", "legendFormat": "Predicción 24h" }
