      "type": "timeseries",
      "targets": [
        { "expr": "hotelflux_erlang_memory_bytes{type=\"total\"}", "legendFormat": "Total" },
        { "expr": "hotelflux_erlang_memory_bytes{type=\"processes\"}", "legendFormat": "Procesos" },
        { "expr": "hotelflux_erlang_memory_bytes{type=\"binary\"}", "legendFormat": "Binary" },
        { "expr": "hotelflux_erlang_memory_bytes{type=\"ets\"}", "legendFormat": "ETS" }
