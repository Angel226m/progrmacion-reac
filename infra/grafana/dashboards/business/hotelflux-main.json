      "title": "Eventos de Seguridad (Loki)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum by (security_event) (rate({service=\"backend\"} | regex \"(?P<security_event>LOGIN_FAILURE|ACCOUNT_LOCKOUT|UNAUTHORIZED|FORBIDDEN)\" [$__interval]))", "legendFormat": "{{security_event}}" }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 10 }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 28 },
      "id": 33,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["sum"] } },
      "title": "Eventos Seguridad (1h)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(count_over_time({service=\"backend\", security_event=~\".+\"}[1h]))", "legendFormat": "Eventos" }]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 28 },
      "id": 34,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["sum"] } },
      "title": "Errores Backend (1h)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(count_over_time({service=\"backend\", level=\"error\"}[1h]))", "legendFormat": "Errores" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
