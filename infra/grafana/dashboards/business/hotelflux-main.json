    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101, "title": "📈 RED Method — Rate / Errors / Duration", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "calcs": ["lastNotNull", "max", "mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "HTTP Rate (req/s)",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(phoenix_router_dispatch_stop_duration_native_count[5m]))", "legendFormat": "Total" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "id": 11,
      "options": { "legend": { "calcs": ["lastNotNull", "max", "mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "HTTP Errors (5xx/s)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(phoenix_router_dispatch_stop_duration_native_count{status=~\"5..\"}[5m]))", "legendFormat": "5xx" },
        { "expr": "sum(rate(phoenix_router_dispatch_stop_duration_native_count{status=~\"4..\"}[5m]))", "legendFormat": "4xx" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 12,
      "options": { "legend": { "calcs": ["lastNotNull", "max", "mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "HTTP Latency (ms) — p50 / p95 / p99",
      "type": "timeseries",
      "targets": [
        { "expr": "job:hotelflux:http_latency_p50_ms", "legendFormat": "p50" },
        { "expr": "job:hotelflux:http_latency_p95_ms", "legendFormat": "p95" },
        { "expr": "job:hotelflux:http_latency_p99_ms", "legendFormat": "p99" }
      ]
    },

