# ═══════════════════════════════════════════════════════════
# HotelFlux — Frontend Cliente (Variables de Entorno)
# ═══════════════════════════════════════════════════════════
#
# En desarrollo: Vite proxy redirige /api/* → localhost:4000 y /socket → ws://localhost:4000
# En producción: sobreescribe estas variables en el entorno del contenedor/Docker.
#
# Ejemplo producción:
#   VITE_API_URL=https://program-react.angelproyect.com/api/v1
#   VITE_WS_URL=wss://program-react.angelproyect.com/socket
# ═══════════════════════════════════════════════════════════

VITE_API_URL=/api/v1
