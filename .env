# ═══════════════════════════════════════════════════════════
# HotelFlux — Variables de Entorno (PLANTILLA)
# Copiar a .env y completar con valores reales ANTES de levantar.
# NUNCA subir .env al control de versiones (está en .gitignore).
# ISO 27001 A.9.4 / OWASP A02:2021 — Cryptographic Failures
# ═══════════════════════════════════════════════════════════

# ── Proyecto ──────────────────────────────────────────────
COMPOSE_PROJECT_NAME=hotelflux-dev
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=hotelflux
POSTGRES_PASSWORD=CAMBIA_ESTO_por_una_clave_segura_min16chars
POSTGRES_DB=hotelflux_dev

# ── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=CAMBIA_ESTO_por_una_clave_segura_redis

# ── Backend Elixir/Phoenix ──────────────────────────────
# Generar con: mix phx.gen.secret  (o: openssl rand -hex 64)
SECRET_KEY_BASE=CAMBIA_ESTO_minimo_64_caracteres_aleatorios_para_Phoenix

# Generar con: openssl rand -hex 32
GUARDIAN_SECRET=CAMBIA_ESTO_clave_aleatoria_para_Guardian_JWT

# Generar con: openssl rand -hex 32
RELEASE_COOKIE=CAMBIA_ESTO_clave_aleatoria_erlang_cookie

# Pool de conexiones Ecto (recomendado: 2 * cores)
POOL_SIZE=10

# ── CORS ────────────────────────────────────────────────
# Orígenes permitidos separados por coma (sin espacios)
# CORS_ORIGINS=http://localhost:3001,https://program-react.angelproyect.com,https://reactiva-personal.angelproyect.com

# ── Host ─────────────────────────────────────────────────
PHX_HOST=localhost

# ── Grafana ──────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CAMBIA_ESTO_por_clave_segura_grafana

# ── Backblaze B2 (Backups automáticos) ──────────────────
B2_BUCKET=HOTELFLUX
B2_ENDPOINT=s3.us-east-005.backblazeb2.com
B2_KEY_ID=b65659a1c844
B2_APP_KEY=0059c00a1b1092ceb3a5bd2e300992c14dc57591bf
B2_REGION=us-east-005
BACKUP_RETENTION_DAYS=10
