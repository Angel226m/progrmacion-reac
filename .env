# ═══════════════════════════════════════════════════════════
# HotelFlux — Desarrollo Local (con Docker)
# ⚠️  SOLO PARA ENTORNOS DE DESARROLLO.  En producción
#     regenerar todos los secretos con `openssl rand -hex 32`.
# ═══════════════════════════════════════════════════════════

# ── Proyecto ──────────────────────────────────────────────
COMPOSE_PROJECT_NAME=hotelflux-dev
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=hotelflux
POSTGRES_PASSWORD=hotelflux_dev_2026
POSTGRES_DB=hotelflux_dev

# ── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=hotelflux_redis_2026

# ── Backend Elixir/Phoenix ──────────────────────────────
DATABASE_URL=ecto://hotelflux:hotelflux_dev_2026@postgres:5432/hotelflux_dev
SECRET_KEY_BASE=super_secret_key_base_min_64_chars_long_for_hotelflux_production_2026
GUARDIAN_SECRET=guardian_jwt_secret_hotelflux_2026_funcional_reactiva
PHX_HOST=localhost
PORT=4000
POOL_SIZE=10
RELEASE_COOKIE=hotelflux_release_cookie_2026

# ── Grafana ──────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=hotelflux_grafana_2026
GRAFANA_PASSWORD=hotelflux_grafana_2026
GRAFANA_USER=admin
