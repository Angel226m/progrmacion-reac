# ═══════════════════════════════════════════════════════════
# HotelFlux — Variables de Entorno (PRODUCCIÓN)
# Copiar a .env y configurar valores reales
# ═══════════════════════════════════════════════════════════

# ── PostgreSQL ──
POSTGRES_USER=hotelflux
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURO_AQUI
POSTGRES_DB=hotelflux_prod

# ── Redis ──
REDIS_PASSWORD=CAMBIAR_REDIS_PASSWORD_AQUI

# ── Backend Elixir/Phoenix ──
# Generar con: mix phx.gen.secret
SECRET_KEY_BASE=GENERAR_CON_mix_phx_gen_secret_MINIMO_64_CARACTERES
GUARDIAN_SECRET=GENERAR_SECRETO_JWT_GUARDIAN_UNICO
PHX_HOST=hotelflux.tudominio.com

# ── Grafana ──
GRAFANA_USER=admin
GRAFANA_PASSWORD=CAMBIAR_GRAFANA_PASSWORD
